# ──────────────────────────────────────
# MyVault 환경변수 예시 — .env로 복사 후 값 채우기
# 절대 Git에 커밋하지 말 것!
# ──────────────────────────────────────

# Supabase (Project Settings → API)
SUPABASE_URL=https://xxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...  # service_role 키 (백엔드 전용)
SUPABASE_ANON_KEY=eyJ...          # anon 키 (프론트엔드 공개 가능)

# Claude API (console.anthropic.com → API Keys)
ANTHROPIC_API_KEY=sk-ant-...

# Telegram (BotFather → /newbot)
TELEGRAM_BOT_TOKEN=123456789:ABCdef...
TELEGRAM_ALLOWED_USER_ID=123456789   # 나의 Telegram User ID (getUpdates로 확인)

# Kakao (선택 — Phase 2)
KAKAO_VERIFY_TOKEN=my-secret-verify-token

# 보안: 백엔드 API 인증 시크릿 (python -c "import secrets; print(secrets.token_urlsafe(32))"로 생성)
API_SECRET_KEY=your-random-secret-key

# Telegram Webhook 서명 시크릿 (setWebhook 호출 시 secret_token 파라미터와 동일)
TELEGRAM_WEBHOOK_SECRET=your-webhook-secret

# 환경 설정
ENV=production
ALLOWED_ORIGINS=https://your-vercel-app.vercel.app

# Frontend (Next.js .env.local에 추가)
NEXT_PUBLIC_API_URL=https://your-railway-app.railway.app
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Supabase JWT 시크릿 (Dashboard → Settings → API → JWT Secret)
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# 백엔드 API 시크릿 (백엔드 API_SECRET_KEY와 동일)
API_SECRET_KEY=your-random-secret-key

# Tavily (신문·기사 OCR 후 관련 웹 기사 검색 — app.tavily.com에서 발급)
TAVILY_API_KEY=tvly-...

# ── GitHub KMS 동기화 (Phase 9-1) ─────────────────────────────────────
# Fine-grained PAT: github.com/settings/personal-access-tokens/new
# Repository: my-kms / Permissions: Contents → Read and write
GITHUB_TOKEN=ghp_...
GITHUB_REPO=kimdw77/my-kms
GITHUB_BRANCH=main
WIKI_DEFAULT_DOMAIN=personal            # personal | kita (분류 안 된 노트 기본값)
SYNC_MODE=realtime                      # realtime | batch
SYNC_LAG_ALERT_SECONDS=30              # HARNESS 3-1: 평균 지연 임계치(초)
SYNC_FAIL_RATE_ALERT_PERCENT=5.0       # HARNESS 3-2: 24h 실패율 임계치(%)
